# Google Maps API key — needs Geocoding, Directions, and Places APIs enabled
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: separate server-side key (falls back to VITE key if not set)
GOOGLE_MAPS_SERVER_KEY=your_server_side_key_here

# Anthropic API key — for AI route explanation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (default: 3006)
PORT=3006
